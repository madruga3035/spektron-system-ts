  "projectTestCaseTags": [
    {
      "id": 5596069,
      "name": "Somente campos obrigatórios",
      "description": "Enviar apenas os campos obrigatórios com valores válidos, omitindo todos os opcionais, para testar a requisição mínima válida."
    },
    {
      "id": 5596070,
      "name": "Semântica válida",
      "description": "Usar valores sintaticamente corretos que também façam sentido na lógica de negócio ou no contexto do domínio."
    },
    {
      "id": 5596071,
      "name": "Cobertura de combinações de enum",
      "description": "Para todos os parâmetros do tipo enum, aplicar design ortogonal para construir sistematicamente combinações de casos de teste dos parâmetros e de seus valores de enum, dedicadas a testar a cobertura de enums."
    },
    {
      "id": 5596072,
      "name": "Outro caso positivo",
      "description": "Fornecer entradas realistas e válidas que atendam à especificação da API, produzindo o resultado correto e esperado."
    },
    {
      "id": 5596073,
      "name": "Campos obrigatórios ausentes",
      "description": "Omitir um ou mais campos obrigatórios no corpo ou nos parâmetros da requisição."
    },
    {
      "id": 5596074,
      "name": "Valores inválidos",
      "description": "Fornecer valores com tipo e formato corretos, mas logicamente inválidos para o campo."
    },
    {
      "id": 5596075,
      "name": "Erros de tipo",
      "description": "Usar valores com tipos de dados incorretos, como enviar uma string em vez de um inteiro."
    },
    {
      "id": 5596076,
      "name": "Erros de formato",
      "description": "Fornecer valores em formato incorreto, por exemplo, padrão de data errado ou endereço de e-mail malformado."
    },
    {
      "id": 5596077,
      "name": "Erros semânticos",
      "description": "Usar valores sintática e formalmente corretos que sejam logicamente impossíveis ou violem regras do domínio."
    },
    {
      "id": 5596078,
      "name": "Outro caso negativo",
      "description": "Fornecer entradas inválidas ou inesperadas que devem acionar o tratamento de erros ou a rejeição pela API."
    },
    {
      "id": 5596079,
      "name": "Nulo",

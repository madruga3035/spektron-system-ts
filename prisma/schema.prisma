// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  
  // Relação: Um usuário pode ter muitos registros de dados
  records   DataRecord[]
}

model DataRecord {
  id          String   @id @default(uuid())
  description String
  value       Float
  createdAt   DateTime @default(now())

  // Chave estrangeira para ligar ao usuário
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}